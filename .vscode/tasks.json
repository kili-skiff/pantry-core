{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: dev server",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/uvicorn",
      "args": ["app.main:app", "--reload", "--port", "8000"],
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "presentation": { "panel": "dedicated", "group": "dev" },
      "problemMatcher": []
    },
    {
      "label": "Frontend: dev server",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "export NVM_DIR=\"$HOME/.nvm\"; [ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\"; npm run dev"
      ],
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "presentation": { "panel": "dedicated", "group": "dev" },
      "problemMatcher": []
    },
    {
      "label": "Start all (backend + frontend)",
      "dependsOn": ["Backend: dev server", "Frontend: dev server"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
