#!/bin/sh
# Goes to ~/.config/labwc/autostart on the Pi. Note: labwc runs this *in
# addition to* /etc/xdg/labwc/autostart, not instead of it - the system
# file's pcmanfm-pi/wf-panel-pi/lxsession-xdg-autostart lines are disabled
# separately (see deploy/setup-kiosk.sh) or you'll get duplicate panels.
# Waits for the backend to answer /health first, since the desktop session
# and the systemd service start independently at boot.
for i in $(seq 1 30); do
  curl -sf http://localhost:8000/health >/dev/null 2>&1 && break
  sleep 1
done

# On-screen keyboard for the touchscreen. Raspberry Pi OS wires squeekboard
# up as a manual toggle button in wf-panel-pi (widget "squeek"), not an
# automatic show-on-focus popup, hence the minimal panel below just for
# that button (config in deploy/wf-panel-pi.ini).
squeekboard &
wf-panel-pi -c ~/.config/wf-panel-pi/wf-panel-pi.ini &

# No --kiosk: that forces a true Wayland fullscreen surface, which on
# labwc/wlroots compositors renders above the panel layer and hides the
# on-screen keyboard entirely (github.com/labwc/labwc/issues/2926). Instead
# a labwc window rule (rc.xml) maximizes + undecorates the chromium window,
# which looks the same but leaves the squeekboard toggle reachable.
# --app instead of a plain URL: opens without tabs/address bar, same look
# as --kiosk, but as a regular (non-fullscreen) window the window rule can
# maximize. Wrapped in lwrespawn (same tool the desktop's own autostart
# uses for its panel/file-manager) so deploy.sh can just kill chromium to
# pick up a new frontend build - it relaunches within a second.
lwrespawn chromium --password-store=basic --noerrdialogs --disable-infobars --incognito --app=http://localhost:8000 &
